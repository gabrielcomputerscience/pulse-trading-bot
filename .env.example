# Deriv developer app id (https://developers.deriv.com) - separate from account token
DERIV_APP_ID=1089

# Legacy manual-token path — not needed if using "Continue with Deriv" (OAuth),
# only used by the /auth/deriv-token fallback endpoint.
DERIV_API_TOKEN=changeme

# Must exactly match a Redirect URI registered for DERIV_APP_ID at
# https://developers.deriv.com. Deriv does not allow localhost redirect
# URLs — this needs to be a real HTTPS URL from your deployed frontend,
# even during early testing.
DERIV_REDIRECT_URI=https://your-frontend-domain.example/oauth/callback

# Comma-separated list of frontend origins allowed to call this API (CORS).
# Update this when your frontend's real domain is known — no code edit needed.
ALLOWED_ORIGINS=https://your-frontend-domain.example

# Always start on demo. Switching to "real" also requires an explicit
# confirm_real_money=true flag per-bot after the 24h forced demo window.
DERIV_ACCOUNT_MODE=demo

# Local dev DB; swap for a Postgres URL in production
DATABASE_URL=sqlite:///./pulse.db

# Used to sign auth JWTs and to key the Fernet encryption for stored tokens.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changeme

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=changeme
