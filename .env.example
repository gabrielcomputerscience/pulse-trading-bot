# Numeric legacy app id for Deriv's WebSocket trading API. The public
# shared default (1089) works fine and needs no registration — this is
# NOT the same thing as an OAuth client_id (see deriv_oauth.py note).
DERIV_LEGACY_APP_ID=1089

# Optional: only relevant if you revisit the OAuth 2.0 code path
# (app/deriv_oauth.py). Not used by the primary PAT-based login flow.
DERIV_APP_ID=1089
DERIV_REDIRECT_URI=https://your-frontend-domain.example/oauth/callback

# Comma-separated list of frontend origins allowed to call this API (CORS).
# Update this when your frontend's real domain is known — no code edit needed.
ALLOWED_ORIGINS=https://your-frontend-domain.example

# Always start on demo. Switching to "real" also requires an explicit
# confirm_real_money=true flag per-bot after the 24h forced demo window.
DERIV_ACCOUNT_MODE=demo

# Local dev DB; swap for a Postgres URL in production
DATABASE_URL=sqlite:///./pulse.db

# Used to sign auth JWTs and to key the Fernet encryption for stored tokens.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changeme

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=changeme
